# ============================================================
# 星蓝心镜 - 后端 API 环境变量配置模板
# 使用方法：cp .env.example .env → 修改实际值
# ============================================================

# ---- 服务器 ----
PORT=3100
NODE_ENV=production

# ---- MySQL 数据库 ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=psy_api
DB_PASS=你的数据库密码
DB_NAME=psy_assessment

# ---- Token 认证 ----
TOKEN_SECRET=随机字符串_至少32位_用于签名JWT
ADMIN_PASSWORD=你的管理员密码

# ---- 微信开放平台（扫码登录，申请后启用） ----
WECHAT_WEB_APPID=
WECHAT_WEB_SECRET=
WECHAT_WEB_REDIRECT_URI=https://www.soarto.com.cn/admin-legacy.html

# ---- CORS 允许的前端域名 ----
CORS_ORIGINS=https://www.soarto.com.cn,https://soarto.com.cn
