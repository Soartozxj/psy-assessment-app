# ============================================================
# 知我心灵测评 - Nginx 反向代理配置
# 站点: www.soarto.com.cn
# 部署路径: /www/server/panel/vhost/nginx/
# ============================================================

server {
    listen 80;
    server_name www.soarto.com.cn soarto.com.cn;
    # 等备案通过后，用 certbot 申请 SSL 证书后取消注释以下行并删除 80 端口配置
    # return 301 https://$host$request_uri;
    
    # 静态文件（前端 H5 页面）
    root /www/wwwroot/www.soarto.com.cn;
    index index.html admin-legacy.html;

    # 前端页面路由（SPA 兼容）
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API 反向代理 → Node.js 服务
    location /api/ {
        proxy_pass http://127.0.0.1:3100;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # 超时设置（AI 诊断可能较慢）
        proxy_read_timeout 60s;
        proxy_send_timeout 30s;
        
        # 请求体大小限制（测评数据含答案和维度）
        client_max_body_size 2m;
    }

    # 健康检查不代理（可选，直接返回 200）
    location = /api/health {
        proxy_pass http://127.0.0.1:3100/;
    }

    # 静态资源缓存（js/css/图片等）
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # 禁止访问隐藏文件和目录
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # 访问日志
    access_log /www/wwwlogs/www.soarto.com.cn.log;
    error_log /www/wwwlogs/www.soarto.com.cn.error.log;
}

