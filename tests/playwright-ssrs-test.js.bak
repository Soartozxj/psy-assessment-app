#!/usr/bin/env node
/**
 * 星蓝心镜 — SSRS 量表新题型测试 (Playwright)
 * 测试矩阵题(matrix)和父子题(parent-child)的渲染、答题与计分
 *
 * 已知限制：phone-body 使用 overflow:hidden，Playwright isVisible() 不可靠
 * 策略：使用 page.evaluate + force: true 点击绕过可见性检查
 *
 * 版本：v3.0 (2026-05-01)
 * 运行：NODE_PATH=/Users/rich/WorkBuddy/20260407113106/node_modules node tests/playwright-ssrs-test.js
 */

const { chromium } = require('playwright');
const BASE_URL = 'http://localhost:8080/frontend/index.html';
let passed = 0, failed = 0, errors = [];

// ========== 辅助函数 ==========

function assert(cond, msg) { if (!cond) throw new Error(msg || 'Assert failed'); }

async function test(name, fn) {
  try {
    await fn();
    passed++;
    console.log(`  ✅ ${name}`);
  } catch (e) {
    failed++;
    errors.push({ name, error: e.message });
    console.log(`  ❌ ${name}: ${e.message.substring(0, 150)}`);
  }
}

/** 在浏览器上下文中执行函数 */
async function evalInPage(page, fn, ...args) {
  return await page.evaluate(fn, ...args);
}

/** 点击元素（force: true 绕过可见性检查） */
async function forceClick(page, selector) {
  await page.click(selector, { force: true });
}

/** 等待指定毫秒 */
async function wait(ms) {
  return new Promise(r => setTimeout(r, ms));
}

/** 强制确认答案（绕过锁） */
async function forceConfirm(page) {
  await page.evaluate(() => { _npcConfirmLock = false; npcConfirmAnswer(); });
}

// ========== 测试用例 ==========

async function runTests() {
  const browser = await chromium.launch({ headless: true });
  const page = await browser.newPage({
    viewport: { width: 375, height: 812 }
  });

  page.on('pageerror', (err) => {
    console.log(`    ⚠️ 页面错误: ${err.message.substring(0, 80)}`);
  });

  // 收集控制台日志
  page.on('console', (msg) => {
    if (msg.text().includes('SSRS') || msg.text().includes('scale') || msg.text().includes('错误') || msg.text().includes('引导')) {
      // console.log(`    [console] ${msg.text().substring(0, 80)}`);
    }
  });

  console.log('\n🧪 SSRS 量表新题型测试 v3.0');
  console.log('='.repeat(55));

  // ====== 模块0：初始化 ======
  console.log('\n📦 模块0: 页面初始化');

  await test('加载页面并设置 localStorage', async () => {
    // 先导航到同源页面（about:blank 无法访问 localStorage）
    await page.goto(BASE_URL);
    await page.waitForLoadState('domcontentloaded');
    // 页面加载前通过 route 注入 localStorage
    await page.evaluate(() => {
      localStorage.setItem('psy_privacy_agreed', 'true');
      localStorage.setItem('psy_user_openid', 'test_user_openid');
      localStorage.setItem('psy_guide_done', 'true');
      localStorage.setItem('psy_guide_version', '2');
    });
    // 刷新页面使 localStorage 生效
    await page.reload();
    await page.waitForLoadState('networkidle');
    await wait(4000);

    // 清理所有遮罩
    await page.evaluate(() => {
      document.querySelectorAll('.guide-overlay, .guide-highlight, .guide-bubble, .guide-arrow-svg').forEach(el => el.remove());
    });
    await wait(500);
  });

  await test('验证 SCALES 数据加载', async () => {
    const result = await page.evaluate(() => {
      if (typeof SCALES === 'undefined') return { error: 'SCALES not defined' };
      const ssrs = SCALES.find(s => s.code === 'SSRS');
      if (!ssrs) return { error: 'SSRS not found', count: SCALES.length, codes: SCALES.map(s => s.code) };
      const qTypes = ssrs.questions.map(q => ({ id: q.id, type: q.type || 'single' }));
      return { found: true, name: ssrs.name, qCount: ssrs.questions.length, qTypes };
    });
    assert(!result.error, `数据加载失败: ${JSON.stringify(result)}`);
    assert(result.found, `SSRS 未找到: ${JSON.stringify(result)}`);
    assert(result.qCount === 10, `题目数不对: ${result.qCount}`);

    const specialTypes = result.qTypes.filter(q => q.type !== 'single');
    assert(specialTypes.length === 3, `新题型数不对: ${JSON.stringify(specialTypes)}`);
    console.log(`    SSRS: ${result.name}, ${result.qCount}题, 新题型: ${specialTypes.map(q => `Q${q.id}(${q.type})`).join(', ')}`);
  });

  await test('验证首页渲染 scale-card', async () => {
    const result = await page.evaluate(() => {
      const cards = document.querySelectorAll('.scale-card');
      if (cards.length === 0) return { error: '无 scale-card', bodyChildren: document.body.children.length };
      let ssrsCard = null;
      cards.forEach(c => { if (c.textContent.includes('社会支持')) ssrsCard = c; });
      return {
        totalCards: cards.length,
        ssrsFound: !!ssrsCard,
        ssrsHtml: ssrsCard ? ssrsCard.textContent.substring(0, 80) : null
      };
    });
    assert(result.totalCards > 0, `首页无卡片: ${JSON.stringify(result)}`);
    assert(result.ssrsFound, `SSRS 卡片未找到`);
    console.log(`    首页卡片: ${result.totalCards}个, SSRS: ${result.ssrsHtml}...`);
  });

  // ====== 模块1：进入测评 ======
  console.log('\n📦 模块1: 进入 SSRS 测评');

  await test('点击 SSRS 进入详情页', async () => {
    await page.evaluate(() => {
      const cards = document.querySelectorAll('.scale-card');
      cards.forEach(c => {
        if (c.textContent.includes('社会支持')) c.click();
      });
    });
    await wait(1500);

    const result = await page.evaluate(() => {
      const detailPage = document.querySelector('.page.scale-detail.active');
      return { detailVisible: !!detailPage, title: detailPage ? detailPage.textContent.substring(0, 60) : null };
    });
    assert(result.detailVisible, `详情页未显示: ${JSON.stringify(result)}`);
    console.log(`    详情页: ${result.title}...`);
  });

  await test('开始测评', async () => {
    const hasStartBtn = await page.evaluate(() => {
      return document.querySelector('#start-assess-btn') !== null;
    });

    if (hasStartBtn) {
      await forceClick(page, '#start-assess-btn');
      await wait(2000);
    }

    // 处理欢迎界面（如果有）
    const welcomeText = await page.evaluate(() => {
      const qText = document.querySelector('#npc-question-text');
      return qText ? qText.textContent : null;
    });

    if (welcomeText && !welcomeText.includes('关系密切')) {
      console.log('    欢迎界面，确认开始');
      await forceConfirm(page);
      await wait(2000);
    }

    const q1Text = await page.evaluate(() => {
      const qText = document.querySelector('#npc-question-text');
      return qText ? qText.textContent : null;
    });
    assert(q1Text && q1Text.includes('关系密切'), `Q1 不匹配: ${q1Text}`);
  });

  // ====== 模块2：单选题 Q1-Q4 ======
  console.log('\n📦 模块2: 单选题 Q1-Q4');

  await test('Q1 选择第2个选项(1~2个, score=2)', async () => {
    const optCount = await page.evaluate(() => {
      return document.querySelectorAll('.npc-option-btn').length;
    });
    assert(optCount >= 4, `Q1 选项数不对: ${optCount}`);

    await page.evaluate(() => {
      document.querySelectorAll('.npc-option-btn')[1].click();
    });
    await wait(300);

    const confirmDisabled = await page.evaluate(() => {
      const btn = document.getElementById('npc-confirm-btn');
      return btn ? btn.disabled : 'not found';
    });
    assert(!confirmDisabled, `确认按钮仍禁用: ${confirmDisabled}`);

    await forceConfirm(page);
    await wait(800);

    const nextQ = await page.evaluate(() => {
      const qText = document.querySelector('#npc-question-text');
      return qText ? qText.textContent : null;
    });
    assert(nextQ && !nextQ.includes('关系密切'), `Q1 未跳转: ${nextQ}`);
    console.log(`    Q1 完成 → ${nextQ.substring(0, 20)}...`);
  });

  await test('Q2-Q4 连续作答', async () => {
    const selections = [2, 1, 3]; // Q2:score=3, Q3:score=2, Q4:score=4
    for (let i = 0; i < 3; i++) {
      const qText = await page.evaluate(() => {
        return document.querySelector('#npc-question-text')?.textContent || '';
      });
      console.log(`    Q${i + 2}: ${qText.substring(0, 15)}... → 选项${selections[i] + 1}`);

      await page.evaluate(({idx}) => {
        document.querySelectorAll('.npc-option-btn')[idx].click();
      }, {idx: selections[i]});
      await wait(300);
      await forceConfirm(page);
      await wait(600);
    }

    const q5Text = await page.evaluate(() => {
      return document.querySelector('#npc-question-text')?.textContent || '';
    });
    assert(q5Text.includes('家庭成员'), `Q5 不匹配: ${q5Text}`);
  });

  // ====== 模块3：矩阵题 Q5 ======
  console.log('\n📦 模块3: 矩阵题 Q5 (matrix)');

  await test('矩阵题表格渲染 - 5行4列', async () => {
    const result = await page.evaluate(() => {
      const form = document.getElementById('npc-matrix-form');
      if (!form) return { error: 'npc-matrix-form 不存在' };
      const rows = form.querySelectorAll('tbody tr');
      const thead = form.querySelector('thead');
      return {
        formExists: true,
        rowCount: rows.length,
        headerText: thead ? thead.textContent.trim() : null,
        rowLabels: Array.from(rows).map(r => r.querySelector('td')?.textContent || ''),
        colsPerRow: rows.length > 0 ? rows[0].querySelectorAll('input[type="radio"]').length : 0
      };
    });
    assert(result.formExists, `矩阵表单不存在: ${JSON.stringify(result)}`);
    assert(result.rowCount === 5, `行数不对: ${result.rowCount}`);
    assert(result.headerText.includes('全力支持'), `列头缺少"全力支持": ${result.headerText}`);
    assert(result.colsPerRow === 4, `每行列数不对: ${result.colsPerRow}`);
    assert(result.rowLabels[0].includes('夫妻'), `第1行标签不对: ${result.rowLabels[0]}`);
    console.log(`    ${result.rowCount}行×${result.colsPerRow}列, 行标签: ${result.rowLabels.join(', ')}`);
  });

  await test('矩阵题交互 - 每行选不同列', async () => {
    // A→col0(无=1), B→col1(极少=2), C→col2(一般=3), D→col3(全力=4), E→col2(一般=3)
    const colChoices = [0, 1, 2, 3, 2];
    for (let r = 0; r < 5; r++) {
      await page.evaluate(({rowIdx, colIdx}) => {
        const row = document.querySelectorAll('#npc-matrix-form tbody tr')[rowIdx];
        row.querySelectorAll('input[type="radio"]')[colIdx].click();
      }, {rowIdx: r, colIdx: colChoices[r]});
      await wait(100);
    }

    const matrixData = await page.evaluate(() => window._matrixAnswers[5]);
    assert(matrixData && Object.keys(matrixData).length === 5,
      `矩阵填写不完整: ${JSON.stringify(matrixData)}`);
    // 预期: {A:0, B:1, C:2, D:3, E:2} → 分数 1+2+3+4+3=13
    console.log(`    矩阵数据: ${JSON.stringify(matrixData)}`);
    console.log(`    预期分: 1+2+3+4+3 = 13`);
  });

  await test('矩阵题确认 → 进入 Q6', async () => {
    await forceConfirm(page);
    await wait(1000);

    const q6Text = await page.evaluate(() => {
      return document.querySelector('#npc-question-text')?.textContent || '';
    });
    assert(q6Text.includes('经济支持') || q6Text.includes('急难'), `Q6 不匹配: ${q6Text}`);
    console.log(`    Q5 完成 → Q6: ${q6Text.substring(0, 30)}...`);
  });

  // ====== 模块4：父子题 Q6 (无任何来源) ======
  console.log('\n📦 模块4: 父子题 Q6 (parent-child - 无任何来源)');

  await test('Q6 主选项渲染 (2个)', async () => {
    const result = await page.evaluate(() => {
      const mainOpts = document.querySelectorAll('.npc-option-btn.npc-pc-main');
      return {
        count: mainOpts.length,
        opt0: mainOpts[0]?.textContent?.trim() || null,
        opt1: mainOpts[1]?.textContent?.trim() || null
      };
    });
    assert(result.count === 2, `Q6 主选项数不对: ${result.count}`);
    assert(result.opt0.includes('无任何来源'), `选项0 不对: ${result.opt0}`);
    assert(result.opt1.includes('下列来源'), `选项1 不对: ${result.opt1}`);
    console.log(`    主选项: ${result.opt0} / ${result.opt1}`);
  });

  await test('选"无任何来源" → 确认按钮可用，子选项区不显示', async () => {
    await page.evaluate(() => {
      document.querySelector('.npc-option-btn.npc-pc-main[data-pc-main="0"]').click();
    });
    await wait(300);

    const result = await page.evaluate(() => {
      const confirmBtn = document.getElementById('npc-confirm-btn');
      const subArea = document.getElementById('npc-sub-options-area');
      return {
        confirmDisabled: confirmBtn ? confirmBtn.disabled : null,
        subAreaExists: !!subArea,
        subAreaActive: subArea ? subArea.classList.contains('active') : false
      };
    });
    assert(!result.confirmDisabled, `确认按钮仍禁用: ${result.confirmDisabled}`);
    assert(!result.subAreaActive, '子选项区不应显示');
    console.log(`    确认可用: ${!result.confirmDisabled}, 子选项区隐藏: ${!result.subAreaActive}`);
  });

  await test('Q6 确认 → 答案为 {main:0}', async () => {
    await forceConfirm(page);
    await wait(800);

    const pcData = await page.evaluate(() => window._pcAnswers ? window._pcAnswers[6] : null);
    assert(pcData && pcData.main === 0, `Q6 答案不对: ${JSON.stringify(pcData)}`);
    console.log(`    Q6 答案: ${JSON.stringify(pcData)}`);
  });

  await test('进入 Q7', async () => {
    const q7Text = await page.evaluate(() => {
      return document.querySelector('#npc-question-text')?.textContent || '';
    });
    assert(q7Text.includes('安慰') || q7Text.includes('关心'), `Q7 不匹配: ${q7Text}`);
    console.log(`    Q7: ${q7Text.substring(0, 30)}...`);
  });

  // ====== 模块5：父子题 Q7 (下列来源+多选+填空) ======
  console.log('\n📦 模块5: 父子题 Q7 (parent-child - 多项+填空)');

  await test('选"下列来源"展开子选项区 (9个)', async () => {
    await page.evaluate(() => {
      document.querySelector('.npc-option-btn.npc-pc-main[data-pc-main="1"]').click();
    });
    await wait(500);

    const result = await page.evaluate(() => {
      const subArea = document.getElementById('npc-sub-options-area');
      if (!subArea) return { error: 'npc-sub-options-area 不存在' };
      const checkboxes = subArea.querySelectorAll('input[type="checkbox"]');
      const labels = Array.from(checkboxes).map(cb => cb.parentElement?.textContent?.trim() || '');
      return {
        active: subArea.classList.contains('active'),
        checkboxCount: checkboxes.length,
        labels
      };
    });
    assert(result.active, '子选项区未展开');
    assert(result.checkboxCount === 9, `子选项数不对: ${result.checkboxCount}`);
    assert(result.labels[0].includes('配偶'), `缺少"配偶": ${result.labels[0]}`);
    assert(result.labels[8].includes('其他'), `缺少"其他": ${result.labels[8]}`);
    console.log(`    ${result.checkboxCount}个: ${result.labels.slice(0, 3).join(', ')}...${result.labels.slice(-2).join(', ')}`);
  });

  await test('勾选"配偶"和"朋友"', async () => {
    await page.evaluate(() => {
      document.querySelector('#npc-sub-A').click();
    });
    await wait(150);
    await page.evaluate(() => {
      document.querySelector('#npc-sub-C').click();
    });
    await wait(150);

    const pcData = await page.evaluate(() => window._pcAnswers[7]);
    assert(pcData.subs.includes('A'), '配偶未选中');
    assert(pcData.subs.includes('C'), '朋友未选中');
    assert(pcData.subs.length === 2, `子选项数不对: ${pcData.subs.length}`);
    console.log(`    已选: ${JSON.stringify(pcData.subs)} (长度: ${pcData.subs.length})`);
  });

  await test('勾选"其他" + 填空"心理老师"', async () => {
    await page.evaluate(() => {
      document.querySelector('#npc-sub-I').click();
    });
    await wait(300);

    const result = await page.evaluate(() => {
      const input = document.getElementById('npc-sub-other-input');
      if (!input) return { error: '输入框不存在' };
      input.value = '心理老师';
      input.dispatchEvent(new Event('input', { bubbles: true }));
      return { inputFound: true, value: input.value };
    });
    assert(result.inputFound, `输入框不存在: ${JSON.stringify(result)}`);

    await wait(200);
    const subFill = await page.evaluate(() => window._pcAnswers[7].subFill);
    assert(subFill && subFill.I === '心理老师', `填空值不对: ${JSON.stringify(subFill)}`);
    console.log(`    "其他"填空: "${subFill.I}"`);
  });

  await test('Q7 确认 → 进入 Q8', async () => {
    await forceConfirm(page);
    await wait(1000);

    const q8Text = await page.evaluate(() => {
      return document.querySelector('#npc-question-text')?.textContent || '';
    });
    assert(q8Text.includes('倾诉'), `Q8 不匹配: ${q8Text}`);
    console.log(`    Q7 完成 → Q8: ${q8Text.substring(0, 25)}...`);
  });

  // ====== 模块6：Q8-Q10 ======
  console.log('\n📦 模块6: 完成单选题 Q8-Q10');

  await test('Q8-Q10 连续作答', async () => {
    const selections = [3, 2, 1]; // Q8:score=4, Q9:score=3, Q10:score=2
    for (let i = 0; i < 3; i++) {
      const qText = await page.evaluate(() => {
        return document.querySelector('#npc-question-text')?.textContent || '';
      });
      console.log(`    Q${i + 8}: ${qText.substring(0, 12)}... → 选项${selections[i] + 1}`);

      await page.evaluate(({idx}) => {
        document.querySelectorAll('.npc-option-btn')[idx].click();
      }, {idx: selections[i]});
      await wait(300);
      await forceConfirm(page);
      await wait(600);
    }
  });

  await test('进入结果页', async () => {
    await wait(2000);
    const result = await page.evaluate(() => {
      const resultPage = document.querySelector('.page.result.active');
      const submitLoading = document.getElementById('npc-submit-loading');
      return {
        resultActive: !!resultPage,
        loadingExists: !!submitLoading,
        bodySnippet: document.body.innerText.substring(0, 200)
      };
    });
    assert(result.resultActive, `结果页未显示, loading: ${result.loadingExists}, body: ${result.bodySnippet.substring(0, 100)}`);
    console.log('    结果页已显示');
  });

  // ====== 模块7：计分验证 ======
  console.log('\n📦 模块7: 计分引擎验证');

  await test('JS 层面直接验证计分', async () => {
    const calcResult = await page.evaluate(() => {
      // 查找 SSRS
      var scales = (typeof DEFAULT_SCALES !== 'undefined') ? DEFAULT_SCALES :
        (typeof SharedData !== 'undefined' && SharedData.scales ? SharedData.scales : null);
      if (!scales) return { error: '无数据源' };
      var ssrs = scales.find(s => s.code === 'SSRS');
      if (!ssrs) return { error: 'SSRS 未找到' };

      // 构造与测试流程完全一致的答案
      var answers = {
        1: 1,       // index=1 → score=2
        2: 2,       // index=2 → score=3
        3: 1,       // index=1 → score=2
        4: 3,       // index=3 → score=4
        5: { A: 0, B: 1, C: 2, D: 3, E: 2 },  // matrix → 1+2+3+4+3=13
        6: { main: 0, subs: [], subFill: {} },   // 无任何来源 → 0
        7: { main: 1, subs: ['A', 'C', 'I'], subFill: { I: '心理老师' } }, // 3个 → 3
        8: 3,       // index=3 → score=4
        9: 2,       // index=2 → score=3
        10: 1       // index=1 → score=2
      };

      // 逐题调用 _collectSpecialScore 验证新题型
      var specialScores = {};
      if (typeof _collectSpecialScore === 'function') {
        for (var qid = 5; qid <= 7; qid++) {
          var q = ssrs.questions.find(x => x.id === qid);
          specialScores['Q' + qid] = _collectSpecialScore(q, answers[qid]);
        }
      }

      // 调用完整计分
      var result = null;
      if (typeof calcScoreBreakdown === 'function') {
        result = calcScoreBreakdown(ssrs, answers);
      } else if (typeof collectScores === 'function') {
        var scores = collectScores(ssrs, answers);
        result = { totalScore: scores.reduce((a, b) => a + b, 0), scores: scores };
      }

      // 计算理论最大最小分
      var maxMin = null;
      if (typeof collectMaxScores === 'function' && typeof collectMinScores === 'function') {
        maxMin = {
          max: collectMaxScores(ssrs).reduce((a, b) => a + b, 0),
          min: collectMinScores(ssrs).reduce((a, b) => a + b, 0)
        };
      }

      return {
        totalScore: result ? result.totalScore : null,
        scores: result ? result.scores : null,
        specialScores,
        maxMin,
        engineUsed: typeof calcScoreBreakdown !== 'undefined' ? 'calcScoreBreakdown' :
          (typeof collectScores !== 'undefined' ? 'collectScores' : 'none')
      };
    });

    if (calcResult.error) {
      console.log(`    ⚠️ 计分引擎调用异常: ${calcResult.error}`);
      return;
    }

    const expected = 36; // 2+3+2+4+13+0+3+4+3+2
    console.log(`    引擎: ${calcResult.engineUsed}`);
    console.log(`    总分: ${calcResult.totalScore} (预期: ${expected})`);
    console.log(`    各题分: [${calcResult.scores ? calcResult.scores.join(', ') : 'N/A'}]`);
    console.log(`    新题型分: ${JSON.stringify(calcResult.specialScores)}`);
    if (calcResult.maxMin) console.log(`    理论范围: ${calcResult.maxMin.min}~${calcResult.maxMin.max}`);

    assert(calcResult.totalScore === expected,
      `总分不匹配: ${calcResult.totalScore} ≠ ${expected}`);

    // 验证各题得分
    const expectedScores = [2, 3, 2, 4, 13, 0, 3, 4, 3, 2];
    const scores = calcResult.scores;
    for (let i = 0; i < expectedScores.length; i++) {
      assert(scores[i] === expectedScores[i],
        `Q${i + 1} 得分不对: ${scores[i]} ≠ ${expectedScores[i]}`);
    }
    console.log(`    各题分逐一验证通过`);
  });

  await test('结果页显示正确分数', async () => {
    const pageText = await page.evaluate(() => document.body.innerText);
    const hasSSRS = pageText.includes('社会支持');

    // 查找分数显示
    const scoreMatch = pageText.match(/(\d+)\s*分/);
    const hasScore = scoreMatch !== null;
    console.log(`    包含"社会支持": ${hasSSRS}`);
    console.log(`    分数显示: ${scoreMatch ? scoreMatch[1] + '分' : '未找到分数文本'}`);

    assert(hasSSRS, '结果页缺少"社会支持"');
    // 注意：结果页分数可能因 AI 分析延迟暂未显示，不强制要求
  });

  // ====== 模块8：边界情况 ======
  console.log('\n📦 模块8: 边界情况');

  await test('矩阵题满分验证', async () => {
    const result = await page.evaluate(() => {
      var scales = typeof DEFAULT_SCALES !== 'undefined' ? DEFAULT_SCALES : null;
      if (!scales) return { error: '无数据' };
      var ssrs = scales.find(s => s.code === 'SSRS');
      if (!ssrs) return { error: 'SSRS未找到' };

      var matrixAns = { A: 3, B: 3, C: 3, D: 3, E: 3 };

      var q5 = ssrs.questions.find(q => q.id === 5);
      if (typeof _collectSpecialScore === 'function') {
        return { score: _collectSpecialScore(q5, matrixAns), expected: 20 };
      }
      return { error: '_collectSpecialScore 不可用' };
    });
    assert(!result.error, `异常: ${result.error}`);
    assert(result.score === result.expected, `矩阵满分不对: ${result.score} ≠ ${result.expected}`);
    console.log(`    矩阵满分: ${result.score} = ${result.expected}`);
  });

  await test('父子题全选验证', async () => {
    const result = await page.evaluate(() => {
      var scales = typeof DEFAULT_SCALES !== 'undefined' ? DEFAULT_SCALES : null;
      if (!scales) return { error: '无数据' };
      var ssrs = scales.find(s => s.code === 'SSRS');
      if (!ssrs) return { error: 'SSRS未找到' };

      var pcAns = {
        main: 1,
        subs: ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I'],
        subFill: { I: 'test' }
      };

      var q7 = ssrs.questions.find(q => q.id === 7);
      if (typeof _collectSpecialScore === 'function') {
        return { score: _collectSpecialScore(q7, pcAns), expected: 9 };
      }
      return { error: '_collectSpecialScore 不可用' };
    });
    assert(!result.error, `异常: ${result.error}`);
    assert(result.score === result.expected, `父子题全选不对: ${result.score} ≠ ${result.expected}`);
    console.log(`    父子题全选: ${result.score} = ${result.expected}`);
  });

  await test('SSRS 总分范围 (min~max)', async () => {
    const result = await page.evaluate(() => {
      var scales = typeof DEFAULT_SCALES !== 'undefined' ? DEFAULT_SCALES : null;
      var ssrs = scales.find(s => s.code === 'SSRS');
      if (!ssrs || typeof collectMaxScores === 'undefined') return { error: '引擎不可用' };

      var maxArr = collectMaxScores(ssrs);
      var minArr = collectMinScores(ssrs);
      return {
        max: maxArr.reduce((a, b) => a + b, 0),
        min: minArr.reduce((a, b) => a + b, 0),
        maxDetail: maxArr,
        minDetail: minArr
      };
    });

    if (result.error) {
      console.log(`    ⚠️ ${result.error}`);
      return;
    }

    // Q1-Q4 单选: min=1*4=4, max=4*4=16
    // Q5 矩阵: min=1*5=5, max=4*5=20
    // Q6 parent-child: min=0(可选无来源), max=9(全选)
    // Q7 parent-child: min=0, max=9
    // Q8-Q10 单选: min=1*3=3, max=4*3=12
    // 总计: min=4+5+0+0+3=12, max=16+20+9+9+12=66
    console.log(`    总分范围: ${result.min} ~ ${result.max}`);
    console.log(`    各题最大分: [${result.maxDetail}]`);
    console.log(`    各题最小分: [${result.minDetail}]`);
    assert(result.min === 12, `最低分不对: ${result.min} ≠ 12`);
    assert(result.max === 66, `最高分不对: ${result.max} ≠ 66`);
  });

  // ====== 汇总 ======
  console.log('\n' + '='.repeat(55));
  if (failed === 0) {
    console.log(`✅ 全部通过: ${passed}/${passed + failed}`);
  } else {
    console.log(`❌ ${failed} 个失败 / ${passed} 个通过`);
    console.log('\n失败用例:');
    errors.forEach(e => console.log(`  - ${e.name}: ${e.error.substring(0, 100)}`));
  }
  console.log('='.repeat(55) + '\n');

  await browser.close();
  process.exit(failed > 0 ? 1 : 0);
}

runTests().catch(e => {
  console.error('测试执行失败:', e.message);
  console.error(e.stack);
  process.exit(1);
});
