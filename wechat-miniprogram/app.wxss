.btn {
  background: var(--primary-color);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
  transition: background 0.2s;
}

.btn:active {
  background: var(--primary-dark);
}

.btn-secondary {
  background: var(--bg-gray);
  color: var(--text-sec);
}

