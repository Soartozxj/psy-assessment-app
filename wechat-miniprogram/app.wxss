/* app.wxss - 全局样式 */

/* 全局变量 */
:root {
  --primary-color: #4A90D9;
  --primary-light: #6BA3E0;
  --primary-dark: #3A7BC8;
  --secondary-color: #F5A623;
  --success-color: #7ED321;
  --warning-color: #F8A600;
  --danger-color: #D0021B;
  --bg-color: #FFFFFF;
  --bg-light: #F8F9FA;
  --bg-gray: #F0F2F5;
  --text: #333333;
  --text-sec: #666666;
  --text-muted: #999999;
  --border: #E5E5E5;
  --border-light: #F0F0F0;
  --shadow-light: 0 2px 12px rgba(0,0,0,0.08);
  --shadow-med: 0 4px 16px rgba(0,0,0,0.12);
  --r-sm: 6rpx;
  --r-md: 10rpx;
  --r-lg: 16rpx;
}

/* 全局重置 */
page {
  background-color: var(--bg-light);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text);
}

/* 容器样式 */
.container {
  padding: 32rpx;
}

/* 卡片样式 */
.card {
  background: var(--bg-color);
  border-radius: var(--r-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-light);
  margin-bottom: 24rpx;
}

/* 按钮样式 */
.btn {
  background: var(--primary-color);
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
  transition: background 0.2s;
}

.btn:active {
  background: var(--primary-dark);
}

.btn-secondary {
  background: var(--bg-gray);
  color: var(--text-sec);
}

.btn-secondary:active {
  background: #E0E0E0;
}

/* 输入框样式 */
.input {
  background: var(--bg-color);
  border: 2rpx solid var(--border);
  border-radius: var(--r-md);
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--text);
}

.input:focus {
  border-color: var(--primary-color);
  outline: none;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: var(--bg-gray);
  color: var(--text-sec);
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-primary {
  background: var(--primary-color);
  color: #fff;
}

/* 标题样式 */
.h1 {
  font-size: 48rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.h2 {
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.h3 {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* 文本样式 */
.text {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text);
}

.text-secondary {
  color: var(--text-sec);
}

.text-muted {
  color: var(--text-muted);
}

/* 间距工具类 */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }

.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }

.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: 16rpx; }

.mr-8 { margin-right: 8rpx; }
.mr-16 { margin-right: 16rpx; }

.p-16 { padding: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* 布局工具类 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.items-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

.justify-center {
  justify-content: center;
}

.flex-1 {
  flex: 1;
}

/* 响应式工具 */
@media (max-width: 375px) {
  .container {
    padding: 24rpx;
  }
  
  .h1 {
    font-size: 40rpx;
  }
  
  .h2 {
    font-size: 32rpx;
  }
  
  .h3 {
    font-size: 28rpx;
  }
}