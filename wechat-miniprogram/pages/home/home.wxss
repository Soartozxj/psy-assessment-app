.home-page { padding: 0 var(--spacing-md); background: #F8F9FA; min-height: 100vh; }

.home-greeting {
  padding: var(--spacing-lg) 0;
}
.greeting-title {
  display: block;
  font-size: 44rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}
.greeting-sub {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.home-search {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.search-icon { margin-right: 12rpx; font-size: 26rpx; }
.search-placeholder { font-size: 26rpx; color: #bbb; }

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #1a1a2e;
}

/* ===== 分类卡片 - 行式双列布局 ===== */
.cat-grid { padding-bottom: 40rpx; }

.cat-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.cat-card {
  width: calc(50% - 10rpx);
  border-radius: 24rpx;
  padding: 32rpx 12rpx 24rpx;
  color: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.12);
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
}
.cat-card:active { transform: scale(0.96); }

.cat-card.full-width {
  width: 100%;
}

.cat-emoji {
  font-size: 56rpx;
  margin-bottom: 10rpx;
  position: relative;
  z-index: 1;
}
.cat-name {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  position: relative;
  z-index: 1;
}
.cat-count {
  font-size: 22rpx;
  opacity: 0.8;
  position: relative;
  z-index: 1;
}

.deco-circle { position: absolute; border-radius: 50%; background: rgba(255,255,255,0.12); }
.deco-top { width: 100rpx; height: 100rpx; top: -26rpx; right: -18rpx; }
.deco-bot { width: 70rpx; height: 70rpx; bottom: -12rpx; left: -10rpx; background: rgba(255,255,255,0.08); }
