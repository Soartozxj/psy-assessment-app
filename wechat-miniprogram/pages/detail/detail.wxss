.detail-page { padding: var(--spacing-md); min-height: 100vh; }

.detail-header {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-card);
}
.detail-emoji { font-size: 72rpx; margin-right: var(--spacing-md); }
.detail-meta { flex: 1; }
.detail-category {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-bottom: 4rpx;
}
.detail-name {
  display: block;
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--color-text);
  line-height: 1.3;
}

.detail-stats {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-sm);
}
.stat {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-sm);
  text-align: center;
  box-shadow: var(--shadow-card);
}
.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 500;
  color: var(--color-primary);
}
.stat-label {
  display: block;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.detail-section {
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-card);
}
.section-title {
  font-size: var(--font-md);
  font-weight: 500;
  margin-bottom: var(--spacing-sm);
  color: var(--color-text);
}
.detail-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.8;
}
.more-link {
  font-size: var(--font-sm);
  color: var(--color-primary);
  display: block;
  margin-top: var(--spacing-xs);
}
.tag-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag {
  font-size: var(--font-xs);
  color: var(--color-primary);
  background: var(--color-primary-light);
  border-radius: var(--radius-sm);
  padding: 4rpx 16rpx;
}

.detail-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: var(--spacing-sm) var(--spacing-md) var(--spacing-lg);
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.05);
}
.start-btn {
  width: 100%;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: var(--font-lg);
  font-weight: 500;
  padding: var(--spacing-sm) 0;
  text-align: center;
  border: none;
}
.start-btn::after { border: none; }
.start-hint {
  display: block;
  text-align: center;
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-top: var(--spacing-xs);
}
