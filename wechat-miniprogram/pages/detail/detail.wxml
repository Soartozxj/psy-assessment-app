<view class="detail-page" wx:if="{{scale}}">
  <view class="detail-header">
    <text class="detail-emoji">{{emoji}}</text>
    <view class="detail-meta">
      <text class="detail-category">{{scale.categoryName}}</text>
      <text class="detail-name">{{scale.name}}</text>
    </view>
  </view>

  <view class="detail-stats">
    <view class="stat"><text class="stat-num">{{scale.questionCount}}</text><text class="stat-label">题目</text></view>
    <view class="stat"><text class="stat-num">{{scale.duration}}</text><text class="stat-label">分钟</text></view>
  </view>

  <view class="detail-section">
    <view class="section-title">量表介绍</view>
    <text class="detail-desc">{{showFullDesc ? scale.desc : descTruncated}}</text>
    <text class="more-link" wx:if="{{scale.desc.length > 120}}" bindtap="toggleDesc">
      {{showFullDesc ? '收起' : '查看更多'}}
    </text>
  </view>

  <view class="detail-section" wx:if="{{scale.tags.length > 0}}">
    <view class="section-title">相关标签</view>
    <view class="tag-list">
      <text class="tag" wx:for="{{scale.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="detail-bottom">
    <button class="start-btn" bindtap="startAssessment">开始测评</button>
    <text class="start-hint">约{{scale.duration}}分钟 · {{scale.questionCount}}道题</text>
  </view>
</view>
