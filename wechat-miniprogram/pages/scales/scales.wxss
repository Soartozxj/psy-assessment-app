.scales-page { padding: var(--spacing-sm); background: #F8F9FA; min-height: 100vh; }

.search-bar {
  display: flex; align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.search-icon { font-size: 26rpx; margin-right: 12rpx; }
.search-input { flex: 1; font-size: 26rpx; }

.cat-tabs { white-space: nowrap; margin-bottom: 16rpx; padding: 4rpx 0; }
.cat-tab {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 14rpx;
  font-size: 24rpx;
  color: #666;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #eee;
}
.cat-tab.active { background: #4A90D9; color: #fff; border-color: #4A90D9; }

.scale-card {
  display: flex; align-items: center;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.04);
  border: 1rpx solid #f0f0f0;
}
.card-left-bar {
  width: 8rpx;
  min-height: 100rpx;
  flex-shrink: 0;
}
.card-body { flex: 1; padding: 20rpx 24rpx; }
.card-title { font-size: 30rpx; font-weight: 600; color: #1a1a2e; margin-bottom: 6rpx; }
.card-tags { margin-bottom: 6rpx; }
.tag {
  display: inline-block;
  font-size: 20rpx;
  color: #4A90D9;
  background: #E8F1FB;
  border-radius: 6rpx;
  padding: 2rpx 12rpx;
  margin-right: 10rpx;
}
.card-meta { display: flex; gap: 20rpx; }
.meta-item { font-size: 22rpx; color: #bbb; }
.card-arrow { font-size: 44rpx; color: #ddd; padding-right: 16rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 160rpx 0; color: #ccc; }
.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-title { font-size: 28rpx; }
