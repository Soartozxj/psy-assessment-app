<view class="scales-page">
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索量表名称..." value="{{searchText}}" bindinput="onSearchInput"/>
  </view>

  <scroll-view class="cat-tabs" scroll-x>
    <view class="cat-tab {{categoryFilter === '' ? 'active' : ''}}" bindtap="onCategoryTap" data-category="">全部</view>
    <view class="cat-tab {{categoryFilter === item.id ? 'active' : ''}}"
          wx:for="{{categories}}" wx:key="id"
          bindtap="onCategoryTap" data-category="{{item.id}}">
      {{item.emoji}} {{item.name}}
    </view>
  </scroll-view>

  <scroll-view class="scale-list" scroll-y>
    <view class="scale-card" wx:for="{{filtered}}" wx:key="code"
          bindtap="onSelectScale" data-code="{{item.code}}">
      <view class="card-left-bar" style="background:{{item.catColor}}"></view>
      <view class="card-body">
        <view class="card-title">{{item.name}}</view>
        <view class="card-tags" wx:if="{{item.tags.length > 0}}">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="t">{{t}}</text>
        </view>
        <view class="card-meta">
          <text class="meta-item">✏️ {{item.questionCount}}题</text>
          <text class="meta-item">⏱ {{item.duration}}分钟</text>
        </view>
      </view>
      <view class="card-arrow">›</view>
    </view>
    <view class="empty-state" wx:if="{{filtered.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-title">没有找到相关量表</text>
    </view>
  </scroll-view>
</view>
