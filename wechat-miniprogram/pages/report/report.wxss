.report-page { padding: var(--spacing-md); min-height: 100vh; background: #F8F9FA; }

.report-header {
  text-align: center;
  padding: var(--spacing-lg) 0;
}
.report-emoji { font-size: 80rpx; display: block; margin-bottom: var(--spacing-sm); }
.report-title { font-size: var(--font-xl); font-weight: 600; color: #1a1a2e; display: block; }
.report-time { font-size: var(--font-xs); color: #bbb; display: block; margin-top: var(--spacing-xs); }

.score-section {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-card);
}
.section-title { font-size: var(--font-lg); font-weight: 600; color: #1a1a2e; margin-bottom: var(--spacing-md); }

.dimension-item { margin-bottom: var(--spacing-sm); }
.dim-row { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.dim-name { font-size: var(--font-sm); color: var(--color-text-secondary); }
.dim-score { font-size: var(--font-md); font-weight: 600; color: var(--color-primary); }

.dim-bar-bg {
  height: 10rpx;
  background: #eee;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 4rpx;
}
.dim-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--color-primary), #6BA3E0);
  border-radius: 5rpx;
  transition: width 0.4s;
}
.dim-level { font-size: var(--font-xs); color: #bbb; }

.action-section {
  padding: var(--spacing-md) 0;
}
.btn-share {
  width: 100%;
  background: var(--color-primary);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  padding: var(--spacing-sm) 0;
  margin-bottom: var(--spacing-sm);
  border: none;
  text-align: center;
}
.btn-share::after { border: none; }

.btn-retest, .btn-home {
  width: 100%;
  background: #fff;
  color: var(--color-text-secondary);
  border-radius: var(--radius-md);
  font-size: var(--font-md);
  padding: var(--spacing-sm) 0;
  margin-bottom: var(--spacing-sm);
  border: 1rpx solid #eee;
  text-align: center;
}
.btn-retest::after, .btn-home::after { border: none; }
