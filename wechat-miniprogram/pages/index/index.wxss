/* pages/index/index.wxss */

.shell-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #E8F2FF 0%, #F5F9FF 40%, #FFFFFF 100%);
  position: relative;
  overflow: hidden;
}

/* ===== 装饰圆 ===== */
.deco-circle {
  position: absolute;
  border-radius: 50%;
  background: #4A90D9;
  pointer-events: none;
  z-index: 0;
}
.deco-1 {
  width: 400rpx; height: 400rpx;
  top: -80rpx; right: -120rpx;
  opacity: 0.06;
}
.deco-2 {
  width: 240rpx; height: 240rpx;
  top: 400rpx; left: -60rpx;
  opacity: 0.06;
}

/* ===== 打字文字层 ===== */
.typing-layer {
  flex-shrink: 0;
  padding: 120rpx 48rpx 0;
  position: relative;
  z-index: 2;
}

/* ===== 艺术字文字（无气泡） ===== */
.bubble-text {
  font-size: 36rpx;
  line-height: 2;
  letter-spacing: 3rpx;
}

/* 艺术字：系统楷体 + 蓝紫渐变光晕 */
.typing-line text {
  font-family: 'Kaiti SC', 'STKaiti', 'KaiTi', '楷体', serif;
  color: #3A6B9F;
  font-weight: 500;
  text-shadow:
    0 2rpx 4rpx rgba(74, 144, 217, 0.2),
    0 4rpx 12rpx rgba(108, 92, 231, 0.12);
}

/* 逐行出现动画 */
.typing-line {
  opacity: 0;
  transform: translateY(12rpx);
  transition: opacity 0.4s ease-out, transform 0.4s ease-out;
}

.typing-line.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ===== 全身人物 ===== */
.character-area {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  position: relative;
  z-index: 1;
  min-height: 0;
}

.character-img {
  display: block;
}

/* ===== 底部按钮区 ===== */
.bottom-area {
  flex-shrink: 0;
  padding: 0 48rpx 80rpx;
  position: relative;
  z-index: 3;
}

/* 进入测评按钮 */
.enter-btn {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #4A90D9, #3A7BC8);
  color: #fff;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(74, 144, 217, 0.35);
}

.enter-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-arrow {
  font-size: 34rpx;
  margin-left: 8rpx;
}

/* ===== 底部 ===== */
.footer-text {
  text-align: center;
  margin-top: 24rpx;
  font-size: 22rpx;
  color: #C0C8D4;
  letter-spacing: 2rpx;
}
