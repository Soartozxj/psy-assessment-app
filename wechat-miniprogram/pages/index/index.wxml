<!--pages/index/index.wxml-->
<view class="shell-page">

  <!-- 装饰圆 -->
  <view class="deco-circle deco-1"></view>
  <view class="deco-circle deco-2"></view>

  <!-- 艺术字文字层（无气泡，直接叠在人物上方） -->
  <view class="typing-layer">
    <view class="bubble-text">
      <view class="typing-line {{item.visible ? 'visible' : ''}}" wx:for="{{typingLines}}" wx:key="index">
        <text>{{item.text}}</text>
      </view>
    </view>
  </view>

  <!-- 全身人物 - 居中展示 -->
  <view class="character-area" bindlongpress="onLongPress">
    <image class="character-img"
      src="/images/npc-character.png"
      mode="widthFix"
      style="width: {{imgDisplayWidth}}%;"
      bindload="onImgLoad"
      binderror="onImgError">
    </image>
  </view>

  <!-- 底部：按钮 + footer -->
  <view class="bottom-area">
    <view class="enter-btn" bindtap="goToFront">
      <text>进入测评</text>
      <text class="btn-arrow"> →</text>
    </view>
    <view class="footer-text">每一种感受，都值得被温柔以待</view>
    <view class="footer-text" style="font-size:11px;opacity:0.4;margin-top:4px;">星蓝心镜 {{version}}</view>
  </view>

</view>
