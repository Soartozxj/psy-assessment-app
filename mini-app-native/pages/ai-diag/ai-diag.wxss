/* AI 诊断页 — 对齐 H5 diag-hero + diag-report 样式 */

.page-ai-diag {
  min-height: 100vh;
  background: #f5f0eb;
  position: relative;
}

/* ===== 头部色块（对齐 H5 diag-hero） ===== */
.diag-hero {
  position: relative;
  z-index: 10;
  padding: 0 0 32rpx;
  overflow: hidden;
}
.diag-hero::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.diag-nav {
  display: flex;
  align-items: center;
  padding: 60rpx 24rpx 16rpx;
  position: relative;
  z-index: 2;
}
.diag-back {
  font-size: 36rpx;
  color: #fff;
  padding: 8rpx 16rpx;
}
.diag-nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-left: 8rpx;
}
.diag-nav-actions {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.diag-action-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 8rpx;
}
.diag-share-btn {
  font-size: 36rpx;
  color: #fff;
  padding: 8rpx;
  background: transparent !important;
  border: none !important;
  line-height: 1;
}
.diag-share-btn::after { border: none; }

.diag-hero-compact {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 32rpx 0;
  position: relative;
  z-index: 2;
}
.diag-hero-icon { font-size: 28rpx; }
.diag-hero-scale { font-size: 26rpx; color: rgba(255,255,255,0.9); font-weight: 600; }
.diag-hero-divider { font-size: 24rpx; color: rgba(255,255,255,0.4); }
.diag-hero-score { font-size: 26rpx; color: rgba(255,255,255,0.9); font-weight: 600; }
.diag-hero-level {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.18);
  padding: 2rpx 16rpx;
  border-radius: 16rpx;
}

/* ===== 内容区 ===== */
.diag-content {
  position: relative;
  z-index: 5;
  padding: 24rpx 32rpx;
  margin-top: -8rpx;
}

/* ===== 状态1：未获取 ===== */
.diag-placeholder {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 24rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}
.diag-placeholder-icon { font-size: 72rpx; display: block; margin-bottom: 16rpx; }
.diag-placeholder-title { font-size: 36rpx; font-weight: 700; color: #3a2e22; display: block; margin-bottom: 12rpx; }
.diag-placeholder-desc { font-size: 26rpx; color: #8b6e50; display: block; margin-bottom: 40rpx; line-height: 1.6; }

.diag-start-btn {
  display: inline-block;
  padding: 24rpx 72rpx;
  background: linear-gradient(135deg, #4a90d9, #5ba0e6);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 24rpx rgba(74, 144, 217, 0.3);
}
.diag-start-btn:active { transform: scale(0.96); }

.diag-error {
  display: block;
  font-size: 26rpx;
  color: #e53935;
  margin-top: 16rpx;
}

/* ===== 状态2：加载中 ===== */
.diag-loading { text-align: center; padding: 120rpx 0; }
.diag-loading-wrap {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 24rpx;
  padding: 64rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}
.diag-loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(74, 144, 217, 0.2);
  border-top-color: #4a90d9;
  border-radius: 50%;
  margin: 0 auto 24rpx;
  animation: diag-spin 0.8s linear infinite;
}
@keyframes diag-spin { to { transform: rotate(360deg); } }

.diag-loading-label { display: block; font-size: 30rpx; color: #3a2e22; font-weight: 600; }
.diag-loading-sub { display: block; font-size: 24rpx; color: #8b6e50; margin-top: 8rpx; }

/* ===== 状态3：已获取 ===== */
.diag-done {}

.diag-section {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.06);
}
.diag-section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px solid rgba(139, 110, 80, 0.12);
}
.diag-section-icon { font-size: 32rpx; }
.diag-section-title { font-size: 30rpx; font-weight: 700; color: #3a2e22; }

/* ===== 报告渲染（对齐 H5 diag-report-text） ===== */
.diag-report-text {
  font-size: 28rpx;
  color: #3a3a3a;
  line-height: 1.8;
}

.diag-block { margin-bottom: 8rpx; }

/* 分隔线 */
.diag-hr {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(139, 110, 80, 0.25), transparent);
  margin: 20rpx 0;
}

/* 标题 */
.diag-heading {
  font-weight: 700;
  color: #3a2e22;
  margin: 16rpx 0 8rpx;
}
.diag-heading-1 { font-size: 34rpx; margin: 20rpx 0 10rpx; }
.diag-heading-2 { font-size: 32rpx; margin: 18rpx 0 8rpx; }
.diag-heading-3 { font-size: 30rpx; font-weight: 600; margin: 14rpx 0 6rpx; }
.diag-heading-4 { font-size: 28rpx; font-weight: 600; margin: 10rpx 0 4rpx; }

/* 引用块 */
.diag-quote {
  background: rgba(74, 144, 217, 0.06);
  border-left: 6rpx solid #4a90d9;
  padding: 12rpx 20rpx;
  margin: 8rpx 0;
  border-radius: 0 8rpx 8rpx 0;
  color: #5a4a38;
  font-size: 26rpx;
  line-height: 1.7;
}

/* 列表 */
.diag-bullet {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 4rpx 0;
}
.diag-bullet-dot { color: #4a90d9; font-size: 28rpx; flex-shrink: 0; line-height: 1.7; }
.diag-bullet-text { font-size: 28rpx; color: #3a3a3a; line-height: 1.7; flex: 1; }

/* 表格行 */
.diag-table-row {
  display: flex;
  background: rgba(139, 110, 80, 0.04);
  border-radius: 8rpx;
  margin: 4rpx 0;
  padding: 8rpx 12rpx;
}
.diag-table-cell {
  flex: 1;
  font-size: 26rpx;
  color: #5a4a38;
  padding: 4rpx 8rpx;
}
.diag-table-cell:first-child { font-weight: 600; color: #3a2e22; }

/* 段落 */
.diag-paragraph {
  font-size: 28rpx;
  color: #3a3a3a;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

/* 行内格式 */
.diag-bold { font-weight: 700; color: #3a2e22; }
.diag-italic { font-style: italic; }
.diag-del { text-decoration: line-through; opacity: 0.6; }
.diag-code {
  background: rgba(0, 0, 0, 0.05);
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  font-size: 26rpx;
  font-family: Menlo, Monaco, monospace;
}

/* ===== 免责声明 ===== */
.diag-disclaimer {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

/* ===== 操作按钮 ===== */
.diag-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}
.diag-btn {
  flex: 1;
  min-width: 0;
  padding: 20rpx 0;
  border-radius: 16rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
}
.diag-btn.retry {
  background: rgba(74, 144, 217, 0.08);
  color: #4a90d9;
}
.diag-btn.tts {
  background: rgba(74, 144, 217, 0.08);
  color: #4a90d9;
}
.diag-btn.tts-loading {
  opacity: 0.6;
}
.diag-btn.share {
  background: linear-gradient(135deg, #4a90d9, #5ba0e6);
  color: #fff;
}
.diag-btn:active { transform: scale(0.96); }

/* ===== TTS 播放器面板 ===== */
.tts-panel {
  margin-top: 16rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  animation: tts-slide-in 0.3s ease-out;
}
@keyframes tts-slide-in {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.tts-panel-inner {
  padding: 24rpx;
}

/* 进度条 */
.tts-progress-wrap { margin-bottom: 20rpx; }
.tts-progress-bar {
  width: 100%;
  height: 6rpx;
  background: rgba(0, 0, 0, 0.08);
  border-radius: 3rpx;
  overflow: hidden;
}
.tts-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 3rpx;
  transition: width 0.3s linear;
}
.tts-time-row {
  display: flex;
  justify-content: space-between;
  margin-top: 6rpx;
}
.tts-time {
  font-size: 20rpx;
  color: #999;
}

/* 语速选择 */
.tts-rate-row, .tts-emotion-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.tts-rate-label {
  font-size: 22rpx;
  color: #8b6e50;
  flex-shrink: 0;
  width: 52rpx;
}
.tts-rate-btn, .tts-emotion-btn {
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  color: #8b6e50;
  background: rgba(255, 255, 255, 0.6);
}
.tts-rate-btn.tts-rate-active, .tts-emotion-btn.tts-emotion-active {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  border-color: transparent;
}
.tts-emotion-btn:active, .tts-rate-btn:active { transform: scale(0.94); }
