/* pages/diary/diary.wxss */
.page-diary {
  padding: 30rpx;
  background: #f8f9fa;
  min-height: 100vh;
}

.diary-date {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.mood-rating-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.mood-stars {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.mood-star {
  font-size: 60rpx;
  opacity: 0.3;
  transition: all 0.3s ease;
}

.mood-star.active {
  opacity: 1;
  transform: scale(1.2);
}

.mood-label {
  text-align: center;
  font-size: 28rpx;
  color: #4a90d9;
  font-weight: 500;
}

.diary-content-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.diary-textarea {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.related-assessment-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.assessment-list {
  max-height: 300rpx;
  overflow-y: auto;
}

.assessment-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background 0.2s ease;
}

.assessment-item.selected {
  background: #f0f7ff;
  border-radius: 8rpx;
}

.assessment-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.assessment-info {
  flex: 1;
}

.assessment-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
}

.assessment-score {
  font-size: 24rpx;
  font-weight: 500;
}

.diary-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.btn-save {
  flex: 1;
  background: #4a90d9;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
}

.btn-save[disabled] {
  background: #ccc;
}

.btn-cancel {
  flex: 1;
  background: #f0f0f0;
  color: #666;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 20rpx 0;
}

.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.diary-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.diary-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.diary-item:last-child {
  border-bottom: none;
}

.diary-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.diary-item-date {
  font-size: 24rpx;
  color: #999;
}

.diary-item-mood {
  font-size: 24rpx;
  color: #4a90d9;
  font-weight: 500;
}

.diary-item-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
