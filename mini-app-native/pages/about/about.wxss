.page-about {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 头部 */
.about-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #5b8fb9, #7eb5d6);
  color: #fff;
}

.app-logo {
  font-size: 96rpx;
  margin-bottom: 16rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.app-version {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 描述 */
.about-desc {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.desc-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 功能区域 */
.feature-section {
  margin: 0 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.feature-card {
  width: calc(50% - 8rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.feature-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.feature-desc {
  display: block;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

/* 链接列表 */
.link-section {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.link-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.link-item:last-child {
  border-bottom: none;
}

.link-item:active {
  background: #f9f9f9;
}

.link-label {
  font-size: 28rpx;
  color: #333;
}

.link-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 底部 */
.about-footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #bbb;
}

.footer-sub {
  font-size: 20rpx;
  color: #ddd;
  margin-top: 8rpx;
}
