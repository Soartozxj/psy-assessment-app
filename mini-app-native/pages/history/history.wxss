.page-history { min-height: 100vh; background: #f5f7fa; }

.cat-tabs {
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.cat-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #666;
  border-radius: 24rpx;
  background: #f5f5f5;
}

.cat-tab.active {
  background: #5b8fb9;
  color: #fff;
}

.record-list { padding: 16rpx 32rpx; }

.date-label {
  padding: 16rpx 0 8rpx;
  font-size: 24rpx;
  color: #999;
}

.record-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.record-emoji { font-size: 36rpx; flex-shrink: 0; }
.record-info { flex: 1; min-width: 0; }
.record-name { display: block; font-size: 28rpx; color: #333; font-weight: 500; }
.record-meta { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }
.record-score { font-size: 28rpx; font-weight: 600; flex-shrink: 0; }
.record-delete { font-size: 24rpx; color: #e0e0e0; padding: 8rpx; flex-shrink: 0; }

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #999; margin-bottom: 24rpx; }
.empty-action {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #5b8fb9, #7eb5d6);
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
}
