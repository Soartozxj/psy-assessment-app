<view class="page-notification">
  <!-- 顶部操作栏 -->
  <view class="action-bar" wx:if="{{notifications.length > 0}}">
    <view class="unread-badge" wx:if="{{unreadCount > 0}}">
      <text class="unread-text">{{unreadCount}} 条未读</text>
    </view>
    <view class="action-btns">
      <text class="action-btn" bindtap="onMarkAllRead">全部已读</text>
      <text class="action-btn danger" bindtap="onClearAll">清空</text>
    </view>
  </view>

  <!-- 通知列表 -->
  <view class="notification-list" wx:if="{{notifications.length > 0}}">
    <view
      class="notification-item {{item.read ? 'read' : 'unread'}}"
      wx:for="{{notifications}}"
      wx:key="id"
      bindtap="onNotificationTap"
      data-id="{{item.id}}"
    >
      <!-- 未读圆点 -->
      <view class="unread-dot" wx:if="{{!item.read}}"></view>

      <!-- 图标 -->
      <view class="notif-icon {{item.type === 'system' ? 'system' : 'assessment'}}">
        <text wx:if="{{item.type === 'system'}}">📢</text>
        <text wx:elif="{{item.type === 'assessment'}}">📋</text>
        <text wx:elif="{{item.type === 'reminder'}}">⏰</text>
        <text wx:else>💬</text>
      </view>

      <!-- 内容 -->
      <view class="notif-content">
        <text class="notif-title">{{item.title}}</text>
        <text class="notif-body">{{item.body}}</text>
        <text class="notif-time">{{item.createdAt}}</text>
      </view>

      <!-- 删除 -->
      <view class="notif-delete" catchtap="onDeleteNotification" data-id="{{item.id}}">
        <text>✕</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{notifications.length === 0}}">
    <text class="empty-icon">🔔</text>
    <text class="empty-text">{{emptyText}}</text>
  </view>
</view>
