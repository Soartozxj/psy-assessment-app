.page-notification {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部操作栏 */
.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.unread-badge {
  flex: 1;
}

.unread-text {
  font-size: 24rpx;
  color: #5b8fb9;
  font-weight: 500;
}

.action-btns {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #5b8fb9;
  padding: 4rpx 0;
}

.action-btn.danger {
  color: #d0021b;
}

/* 通知列表 */
.notification-list {
  margin-top: 16rpx;
}

.notification-item {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 2rpx solid #f5f5f5;
  position: relative;
}

.notification-item.unread {
  background: #f0f7ff;
}

.unread-dot {
  position: absolute;
  top: 28rpx;
  left: 16rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #5b8fb9;
}

/* 图标 */
.notif-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.notif-icon.system { background: #fff3e0; }
.notif-icon.assessment { background: #e3f2fd; }

/* 内容 */
.notif-content {
  flex: 1;
  min-width: 0;
}

.notif-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-item.unread .notif-title {
  color: #1a1a1a;
}

.notif-body {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.notif-time {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 删除按钮 */
.notif-delete {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
  font-size: 28rpx;
  border-radius: 50%;
}

.notif-delete:active {
  background: #f0f0f0;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
