.page-privacy {
  min-height: 100vh;
  background: #fff;
  padding-bottom: calc(env(safe-area-inset-bottom) + 120rpx);
}

/* 标题区域 */
.policy-header {
  padding: 40rpx 32rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.policy-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 12rpx;
}

.policy-update-date {
  display: block;
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

/* 内容区域 */
.policy-content {
  padding-bottom: 24rpx;
}

/* 章节通用 */
.policy-section {
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #f8f8f8;
}

.section-heading {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.section-intro {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

.section-text {
  display: block;
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.section-list {
  padding-left: 16rpx;
}

.list-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

/* 复制按钮 */
.copy-btn {
  margin: 32rpx;
  text-align: center;
  padding: 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #999;
}

.copy-btn:active {
  background: #f5f5f5;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}

.btn-reject {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #666;
}

.btn-reject:active {
  background: #f5f5f5;
}

.btn-agree {
  flex: 2;
  text-align: center;
  padding: 22rpx;
  background: linear-gradient(135deg, #5b8fb9, #7eb5d6);
  border-radius: 48rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(91, 143, 185, 0.3);
}

.btn-agree:active {
  opacity: 0.85;
}

/* 已同意提示 */
.agreed-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  text-align: center;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}

.agreed-text {
  font-size: 26rpx;
  color: #7ed321;
  font-weight: 500;
}
