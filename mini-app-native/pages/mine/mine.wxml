<view class="page-mine">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info" bindtap="onEditProfile">
      <view class="user-avatar">
        <image class="avatar-img" src="{{avatarUrl}}" wx:if="{{avatarUrl}}" mode="aspectFill" />
        <view class="avatar-placeholder" wx:else>
          <text>👤</text>
        </view>
      </view>
      <view class="user-detail">
        <text class="user-name">{{nickName}}</text>
        <text class="user-edit-hint">点击编辑资料 ›</text>
      </view>
    </view>
  </view>

  <!-- 测评统计 -->
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-val">{{totalDone}}</text>
      <text class="stat-label">已完成</text>
    </view>
    <view class="stat-item">
      <text class="stat-val">{{recentDone}}</text>
      <text class="stat-label">近7天</text>
    </view>
    <view class="stat-item">
      <text class="stat-val">{{favoritesCount}}</text>
      <text class="stat-label">收藏</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view
      class="menu-item"
      wx:for="{{menuList}}"
      wx:key="key"
      data-url="{{item.url}}"
      bindtap="onMenuTap"
    >
      <text class="menu-icon">{{item.icon}}</text>
      <text class="menu-label">{{item.label}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>
