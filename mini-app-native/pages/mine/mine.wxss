.page-mine { min-height: 100vh; background: #f5f7fa; }

.user-card {
  background: linear-gradient(135deg, #5b8fb9, #7eb5d6);
  padding: 48rpx 32rpx;
}

.user-info { display: flex; align-items: center; gap: 24rpx; }

.user-avatar {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  overflow: hidden; background: rgba(255,255,255,0.3);
  flex-shrink: 0;
}

.avatar-img { width: 100%; height: 100%; }

.avatar-placeholder {
  width: 100%; height: 100%;
  display: flex; align-items: center; justify-content: center;
  font-size: 56rpx;
}

.user-detail { flex: 1; }
.user-name { display: block; font-size: 36rpx; font-weight: 700; color: #fff; }
.user-edit-hint { display: block; font-size: 24rpx; color: rgba(255,255,255,0.7); margin-top: 8rpx; }

/* 统计 */
.stats-row {
  display: flex;
  background: #fff;
  margin: -20rpx 32rpx 0;
  border-radius: 20rpx;
  padding: 28rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 1;
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 2rpx solid #f0f0f0;
}

.stat-item:last-child { border-right: none; }
.stat-val { display: block; font-size: 40rpx; font-weight: 700; color: #5b8fb9; }
.stat-label { display: block; font-size: 22rpx; color: #999; margin-top: 4rpx; }

/* 菜单 */
.menu-list {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; }
.menu-label { flex: 1; font-size: 28rpx; color: #333; }
.menu-arrow { font-size: 28rpx; color: #ccc; }
