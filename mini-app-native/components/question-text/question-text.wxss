.question-text { padding: 0; }
.q-header { margin-bottom: 8rpx; }
.q-number { font-size: 24rpx; color: #5b8fb9; font-weight: 600; }
.q-content { font-size: 30rpx; color: #1a1a2e; line-height: 1.6; margin-bottom: 20rpx; }

.text-wrap {
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(91, 143, 185, 0.15);
}

.text-input {
  width: 100%;
  min-height: 160rpx;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.6;
  box-sizing: border-box;
  background: #fff;
}

.text-input.single-line {
  min-height: auto;
  height: 72rpx;
}

.char-counter {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}
