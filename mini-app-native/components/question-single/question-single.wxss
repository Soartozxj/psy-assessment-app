.question-single {
  padding: 0;
}

.q-header {
  margin-bottom: 8rpx;
}

.q-number {
  font-size: 24rpx;
  color: #5b8fb9;
  font-weight: 600;
}

.q-content {
  font-size: 30rpx;
  color: #1a1a2e;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.options-area {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(91, 143, 185, 0.15);
}

.option-btn {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx;
  background: linear-gradient(135deg, #f0f6fa 0%, #e8f2f8 100%);
  border: 3rpx solid rgba(91, 143, 185, 0.25);
  border-radius: 16rpx;
  transition: all 0.25s ease;
  font-size: 26rpx;
  color: #3a5a6e;
  line-height: 1.4;
}

.option-btn.selected {
  background: linear-gradient(135deg, #5b8fb9, #7eb5d6);
  color: #fff;
  border-color: #5b8fb9;
  transform: translateX(6rpx);
  box-shadow: 0 4rpx 16rpx rgba(91, 143, 185, 0.3);
}

.option-btn.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.option-letter-wrap {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(91, 143, 185, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.25s ease;
}

.option-letter-wrap.selected {
  background: rgba(255, 255, 255, 0.25);
}

.option-letter {
  font-weight: 700;
  font-size: 22rpx;
  color: #5b8fb9;
}

.option-letter-wrap.selected .option-letter {
  color: #fff;
}

.option-label {
  flex: 1;
  font-size: 28rpx;
}
