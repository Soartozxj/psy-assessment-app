.score-ring-wrap {
  position: relative;
  flex-shrink: 0;
}

.score-ring-canvas {
  display: block;
}

.score-ring-info {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.ring-val {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1;
}

.ring-max {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.ring-pct {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 2rpx;
}

.level-label {
  padding: 4rpx 24rpx;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  margin-top: 8rpx;
}
