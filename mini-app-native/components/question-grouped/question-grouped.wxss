.question-grouped { padding: 0; }
.q-header { margin-bottom: 8rpx; }
.q-number { font-size: 24rpx; color: #5b8fb9; font-weight: 600; }
.q-content { font-size: 30rpx; color: #1a1a2e; line-height: 1.6; margin-bottom: 20rpx; }

.group-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(91, 143, 185, 0.15);
}

.group-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.group-label {
  min-width: 100rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #5b8fb9;
  text-align: right;
}

.group-picker { flex: 1; }

.picker-text {
  padding: 16rpx 20rpx;
  border: 2rpx solid rgba(91, 143, 185, 0.3);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #999;
  background: #fff;
}

.picker-text.selected {
  color: #3a5a6e;
}

/* allowRepeat */
.repeat-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.repeat-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #f0f6fa;
  border-radius: 12rpx;
}

.repeat-item-label { font-size: 28rpx; color: #3a5a6e; font-weight: 500; }
.repeat-item-del { font-size: 28rpx; color: #e57373; padding: 8rpx; }

.repeat-edit {
  background: #fff;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.repeat-edit-title {
  font-size: 28rpx;
  color: #5b8fb9;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.repeat-form { display: flex; flex-direction: column; gap: 16rpx; }

.repeat-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.repeat-row-label {
  min-width: 80rpx;
  font-size: 24rpx;
  color: #7a9bae;
}

.repeat-picker { flex: 1; }

.repeat-edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.repeat-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.repeat-btn.confirm {
  background: linear-gradient(135deg, #5b8fb9, #7eb5d6);
  color: #fff;
}

.repeat-btn.cancel {
  background: #f5f5f5;
  color: #999;
}

.repeat-add {
  width: 100%;
  padding: 24rpx 0;
  border: 4rpx dashed #ccc;
  border-radius: 16rpx;
  text-align: center;
  margin-top: 8rpx;
}

.repeat-add-text {
  font-size: 28rpx;
  color: #5b8fb9;
}
