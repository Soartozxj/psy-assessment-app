<view class="question-pc">
  <view class="q-header" wx:if="{{showIndex && index > 0}}">
    <text class="q-number">【第{{index}}题】</text>
  </view>
  <view class="q-content" wx:if="{{npcMode !== 'immersive'}}">{{question.content}}</view>

  <!-- 主选项 -->
  <view class="main-options">
    <view
      class="main-btn {{selectedMain == item.idx ? 'selected' : ''}} {{disabled ? 'disabled' : ''}}"
      wx:for="{{mainOptions}}"
      wx:key="idx"
      data-index="{{item.idx}}"
      bindtap="onSelectMain"
    >
      <view class="option-letter-wrap {{selectedMain == item.idx ? 'selected' : ''}}">
        <text class="option-letter">{{item.letter}}</text>
      </view>
      <text class="option-label">{{item.label}}</text>
    </view>
  </view>

  <!-- 子选项（动画展开） -->
  <view class="sub-options {{showSubs ? 'active' : ''}}">
    <view class="sub-title" wx:if="{{showSubs}}">请选择具体来源：</view>
    <view class="sub-list" wx:if="{{showSubs}}">
      <view
        class="sub-item {{selectedSubsMap[item.idx] ? 'checked' : ''}}"
        wx:for="{{subOptions}}"
        wx:key="idx"
        data-index="{{item.idx}}"
        bindtap="onCheckSub"
      >
        <view class="sub-checkbox {{selectedSubsMap[item.idx] ? 'checked' : ''}}">
          <view class="check-icon" wx:if="{{selectedSubsMap[item.idx]}}">✓</view>
        </view>
        <text class="sub-label">{{item.label}}</text>
      </view>
      <!-- "其他"输入框 -->
      <view class="sub-input-row" wx:if="{{showSubs && subOptions.length > 0}}">
        <input
          class="other-input"
          placeholder="请填写具体内容"
          value="{{otherText}}"
          bindinput="onOtherInput"
          disabled="{{disabled}}"
        />
      </view>
    </view>
  </view>
</view>
