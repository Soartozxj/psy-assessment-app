.feedback-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.feedback-card {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-width: 600rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.fb-title {
  text-align: center;
  margin-bottom: 28rpx;
}

.fb-title text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.fb-stars {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.star {
  font-size: 56rpx;
  color: #ddd;
  transition: color 0.2s;
}

.star.active {
  color: #ffc107;
}

.fb-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.fb-tag {
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid #e8e8e8;
  transition: all 0.2s;
}

.fb-tag.selected {
  background: rgba(91, 143, 185, 0.1);
  color: #5b8fb9;
  border-color: #5b8fb9;
}

.fb-textarea {
  width: 100%;
  height: 160rpx;
  padding: 16rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}

.fb-actions {
  display: flex;
  gap: 20rpx;
}

.fb-btn {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.fb-btn.cancel {
  background: #f5f5f5;
  color: #999;
}

.fb-btn.submit {
  background: linear-gradient(135deg, #5b8fb9, #7eb5d6);
  color: #fff;
}

.fb-btn.submit.disabled {
  opacity: 0.5;
}
