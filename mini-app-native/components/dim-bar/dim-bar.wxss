.dim-bar-comp {
  margin-bottom: 24rpx;
}

.dim-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.dim-label {
  font-size: 28rpx;
  color: #1a1a2e;
  flex: 1;
  margin-right: 16rpx;
}

.dim-head-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.dim-score-tag {
  font-size: 28rpx;
  font-weight: 600;
}

.dim-max {
  font-size: 22rpx;
  color: #aaa;
}

.dim-level-badge {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
}

.dim-expand-icon {
  font-size: 22rpx;
  color: #999;
  padding: 4rpx 8rpx;
}

.dim-bar-wrap {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.dim-bar {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.6s ease;
  min-width: 0;
}

/* 维度解释文字（直接展示，无需点击展开） */
.dim-explain {
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(0, 0, 0, 0.03);
  border-radius: 12rpx;
  border-left: 4rpx solid #5b8fb9;
}

.dim-explain-text {
  font-size: 26rpx;
  color: #5a4a38;
  line-height: 1.65;
}
